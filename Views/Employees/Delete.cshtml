@model HRMS.Mvc.Models.Employee
@{
    ViewData["Title"] = "Delete Employee";
    ViewData["Subtitle"] = "Confirm removal";
}

<div class="page-form narrow">
    <div class="danger-panel">
        <div class="danger-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><path d="M12 9v4M12 17h.01"/></svg>
        </div>
        <h2>Delete @Model.FirstName @Model.LastName?</h2>
        <p>This permanently removes the employee record. Payroll history linked to this person may be affected.</p>

        <dl class="detail-list compact">
            <dt>Email</dt>
            <dd>@(string.IsNullOrWhiteSpace(Model.Email) ? "—" : Model.Email)</dd>
            <dt>Department</dt>
            <dd>@(Model.Department?.DepartmentName ?? "—")</dd>
            <dt>Designation</dt>
            <dd>@(Model.Designation?.DesignationName ?? "—")</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="EmployeeID" />
            <div class="form-actions">
                <a asp-action="Index" class="btn btn-secondary">Keep employee</a>
                <button type="submit" class="btn btn-danger">Delete permanently</button>
            </div>
        </form>
    </div>
</div>
